{
  "name": "loa-lobby-logs",
  "version": "1.0.1",
  "private": true,
  "description": "Personal Lost Ark lobby log overlay.",
  "type": "module",
  "main": "dist/src/main/electron.js",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-renderer-assets.mjs",
    "start": "tsc && node scripts/copy-renderer-assets.mjs && electron .",
    "package:win": "tsc && node scripts/copy-renderer-assets.mjs && electron-builder --win portable",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.puhpit.loa-lobby-logs",
    "productName": "LOA Lobby Logs",
    "files": [
      "dist/src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "portable"
      ],
      "icon": "build/icon.ico",
      "artifactName": "LOA-Lobby-Logs-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "tesseract.js": "^6.0.0"
  }
}
