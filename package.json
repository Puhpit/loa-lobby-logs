{
  "name": "loa-lobby-logs",
  "version": "0.1.0",
  "private": true,
  "description": "Personal Lost Ark lobby log overlay.",
  "type": "module",
  "main": "dist/main/electron.js",
  "scripts": {
    "build": "tsc && node scripts/copy-renderer-assets.mjs",
    "start": "npm run build && electron .",
    "package:win": "npm run build && electron-builder --win portable",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "build": {
    "appId": "com.puhpit.loa-lobby-logs",
    "productName": "LOA Lobby Logs",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "LOA-Lobby-Logs-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "tesseract.js": "^6.0.0",
    "electron": "^35.0.0"
  }
}
